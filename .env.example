# Neon entrega una URL compatible con PostgreSQL. Mantenga sslmode=require.
DATABASE_URL=postgresql://USUARIO:CLAVE@HOST/BASE?sslmode=require
LOG_LEVEL=INFO
MAX_UPLOAD_MB=200

# Solo para el gateway de Vercel; debe apuntar al host persistente de Streamlit.
STREAMLIT_APP_URL=https://su-aplicacion-streamlit.example.com

